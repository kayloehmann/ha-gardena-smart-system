      "automower_activity": {
        "default": "mdi:robot-mower"
      },
      "automower_state": {
        "default": "mdi:information-outline"
      }
    },
    "binary_sensor": {
      "valve_error": {
        "default": "mdi:pipe-leak"
      },
      "mower_error": {
        "default": "mdi:robot-mower-outline"
      },
      "automower_error": {
        "default": "mdi:alert-circle-outline"
      },
      "automower_connected": {
        "default": "mdi:cloud-check-outline",
        "state": {
          "on": "mdi:cloud-check-outline",
          "off": "mdi:cloud-off-outline"
        }
      }
    },
    "switch": {
      "power_socket": {
        "default": "mdi:power-socket-eu",
        "state": {
          "on": "mdi:power-socket-eu",
          "off": "mdi:power-socket-eu"
        }
      },
      "automower_headlight": {
        "default": "mdi:car-light-high",
        "state": {
          "on": "mdi:car-light-high",
          "off": "mdi:car-light-dimmed"
        }
      },
      "automower_stay_out_zone": {
        "default": "mdi:map-marker-off",
        "state": {
          "on": "mdi:map-marker-off",
          "off": "mdi:map-marker-check"
        }
      }
    },
    "valve": {
      "valve": {
        "default": "mdi:sprinkler-variant",
        "state": {
          "open": "mdi:sprinkler",
          "closed": "mdi:sprinkler-variant"
        }
      }
    },
    "lawn_mower": {
      "mower": {
        "default": "mdi:robot-mower",
        "state": {
          "mowing": "mdi:robot-mower",
          "docked": "mdi:robot-mower-outline",
          "paused": "mdi:pause",
          "error": "mdi:alert-circle-outline"
        }
      },
      "automower": {
        "default": "mdi:robot-mower",
        "state": {
          "mowing": "mdi:robot-mower",
          "docked": "mdi:robot-mower-outline",
          "paused": "mdi:pause",
          "error": "mdi:alert-circle-outline"
        }
      }
    },
    "number": {
      "automower_cutting_height": {
        "default": "mdi:grass"
      },
      "automower_work_area_cutting_height": {
        "default": "mdi:grass"
      }
    },
    "device_tracker": {
      "automower_position": {
        "default": "mdi:crosshairs-gps"
      }
    },
    "calendar": {
      "automower_schedule": {
        "default": "mdi:calendar-clock"
      }
    }
