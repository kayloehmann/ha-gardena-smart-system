{
  "config": {
    "step": {
      "user": {
        "title": "Husqvarnaに接続",
        "description": "Husqvarna開発者ポータルのアプリケーション認証情報を入力してください。",
        "data": {
          "client_id": "アプリケーションキー (Client ID)",
          "client_secret": "アプリケーションシークレット"
        },
        "data_description": {
          "client_id": "Husqvarna開発者アカウントのアプリケーションキー。",
          "client_secret": "Husqvarna開発者アカウントのアプリケーションシークレット。"
        }
      },
      "api_type": {
        "title": "APIを選択",
        "description": "接続するHusqvarna APIを選択してください。統合を2回設定することで両方を追加できます。",
        "data": {
          "api_type": "API"
        }
      },
      "location": {
        "title": "庭を選択",
        "description": "アカウントに複数の庭が見つかりました。追加したい庭を選択してください。",
        "data": {
          "location_id": "庭"
        }
      },
      "reauth_confirm": {
        "title": "再認証",
        "description": "認証情報が無効になりました。アプリケーション認証情報を再入力してください。",
        "data": {
          "client_id": "アプリケーションキー (Client ID)",
          "client_secret": "アプリケーションシークレット"
        }
      },
      "reconfigure": {
        "title": "再設定",
        "description": "アプリケーション認証情報を更新してください。",
        "data": {
          "client_id": "アプリケーションキー (Client ID)",
          "client_secret": "アプリケーションシークレット"
        }
      },
      "reconfigure_location": {
        "title": "庭を選択",
        "description": "複数の庭が見つかりました。このエントリが使用する庭を選択してください。",
        "data": {
          "location_id": "庭"
        }
      }
    },
    "error": {
      "invalid_auth": "認証情報が無効です。Husqvarna開発者ポータルでアプリケーションキーとシークレットを確認してください。",
      "forbidden": "APIアクセスが拒否されました。Husqvarna開発者ポータルでGardena Smart System APIがアプリケーションに接続されていることを確認してください。",
      "automower_not_connected": "Automower Connect APIがアプリケーションに接続されていません。Husqvarna開発者ポータルの接続済みAPIで有効にしてください。",
      "rate_limited": "APIレート制限に達したか、一時的にブロックされています。数分待ってから再試行するか、Husqvarna開発者ポータルで新しいアプリケーションを作成してください。",
      "cannot_connect": "APIに接続できません。ネットワーク接続を確認して再試行してください。",
      "unknown": "予期しないエラーが発生しました。"
    },
    "abort": {
      "already_configured": "この設定は既に存在します。",
      "reauth_successful": "再認証が成功しました。",
      "reconfigure_successful": "再設定が成功しました。"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Gardena Smart Systemオプション",
        "data": {
          "default_watering_minutes": "デフォルト散水時間",
